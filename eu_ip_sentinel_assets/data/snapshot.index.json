ount":3},{"date":"2026-04-06","count":4},{"date":"2026-04-07","count":25},{"date":"2026-04-08","count":12},{"date":"2026-04-09","count":12},{"date":"2026-04-10","count":15},{"date":"2026-04-11","count":1}],"last_scrape_time":"2026-04-11 08:30:00","last_analyze_time":"2026-04-11 08:47:52","last_quality_guard_time":"2026-04-11 06:44:38","last_verification_time":"2026-04-11 14:51:12","active_source_count":43,"source_tier_core_count":25,"source_tier_stable_count":10,"source_tier_watch_count":8,"duplicate_candidate_groups":0,"duplicate_candidate_items":0,"event_cluster_count":16,"multi_item_event_count":16,"multi_source_event_count":3,"scrape_runs_24h":106,"scrape_success_rate_24h":100.0,"scrape_found_24h":500,"scrape_new_24h":51,"ai_runs_24h":5,"ai_success_rate_24h":100.0,"ai_attempted_24h":82,"ai_success_24h":82,"ai_failed_24h":0,"quality_guard_runs_24h":4,"quality_guard_success_rate_24h":100.0,"quality_guard_matched_24h":49,"quality_guard_deleted_24h":49,"verification_runs_24h":9,"verification_success_rate_24h":100.0,"verification_attempted_24h":24,"verification_pass_24h":6,"verification_review_24h":7,"verification_fail_24h":5,"verification_error_24h":6,"next_scrape":"2026-04-11 18:30 CEST","next_public_sync":"2026-04-11 20:15 CEST","total_sources":53,"collection_start_date":"2026-02-01 00:00:00","collection_end_date":"2026-04-11 23:59:59"},"intel_overview":{"headline_zh":"UPC 严审统一专利，欧盟商标反欺诈升级","headline_en":"UPC Strictness Rises, EU Trademark Fraud Crackdown Intensifies","summary_zh":"欧洲 IP 生态呈现“程序优化与实体严管”双轨态势。EPO 推行 DOCX 格式提升审查效率，法美 PPH 加速跨国确权；但 UPC 上诉法院确立严苛判例，拒绝非全覆盖的统一专利效力，并明确登录系统不构成管辖应诉。同时，欧盟法院强化商标真实性审查，打击虚构历史年份行为。整体环境对申请形式合规性及品牌资产真实性提出更高要求。","top_signals":["UPC 上诉法院裁定未全覆盖成员国即拒授统一专利效力","确认仅登录 UPC 系统查看文件不构成接受法院管辖","欧盟法院判定无实际传承的虚构年份商标构成欺骗","EPO 全面开放 DOCX 格式提交以优化审查工作流"],"cross_currents":["UPC 正从初期的包容探索转向严格的形式主义法治，领土完整性成为不可逾越的红线。","数字化便利（如 DOCX、在线系统）正在普及，但法律风险的触发点变得更加隐蔽且具体。","品牌资产估值逻辑生变，单纯的商标受让若无业务实质承接，将面临严重的确权与维权障碍。"],"implications":["存量欧洲专利需紧急排查成员国覆盖情况，避免因缺漏马耳他等小国而丧失统一保护资格。","应对 UPC 诉讼时，仅做后台监控是安全的，但提交任何正式文书前必须完成管辖权评估。","收购欧洲老字号品牌时，务必核实是否包含整体业务资产，避免使用虚构年份营销引发无效风险。"],"watchlist":["UPC 针对其他程序性瑕疵（如翻译错误、缴费延迟）的后续判例走向","法国新战略规划下，其作为欧洲专利诉讼热门地的案件数量变化","欧盟各国对奢侈品商标“历史传承”举证责任的具体执行标准细化"],"item_count":6,"source_count":4,"date_from":"2026-02-01 00:00:00","date_to":"2026-04-11 23:59:59","model":"qwen3.5-plus","generated_from_cache":true,"cached_at":"2026-04-11 12:52:02"},"daily_report":{"headline_zh":"UPC 严控专利领土完整与管辖权确立标准","headline_en":"UPC Tightens Unitary Patent Territory and Jurisdiction Rules","summary_zh":"本周 UPC 上诉法院连发两则重要裁定，显著收紧程序合规门槛。首先，法院明确拒绝因历史原因未覆盖马耳他的旧案获得统一专利效力，强调领土完整性不可豁免；其次，裁定仅登录系统查看文件不构成应诉管辖，明确了管辖权确立的实体行为标准。这两项动态要求企业在存量专利排查及诉讼应对策略上必须更加严谨，避免因形式瑕疵丧失权利或误触管辖陷阱。","key_moves":["UPC 上诉法院拒绝对未全覆盖成员国的旧案授予统一专利效力","法院确认仅登录系统查看文件不视为接受管辖权","确立必须以提交初步异议或答辩状作为应诉管辖标准","重申严格适用条例，不因非申请人过错豁免领土完整性要求"],"business_actions":["立即排查存量欧洲专利，确认是否因缺漏成员国而丧失统一保护资格","在 UPC 诉讼中可安全登录查看案情，但提交任何文书前须审慎评估管辖风险","新申请策略须确保权利要求在所有参与成员国完全一致以符合形式审查"],"watchlist":["UPC 对其他国家缺漏案件的后续裁定趋势","布鲁塞尔条例下关于电子送达与管辖权确立的细化解释","中国企业涉及 UPC 诉讼时的早期程序应对策略调整"],"report_items":[{"id":8960,"source_id":"mondaq","source_name":"Mondaq","category":"media","ip_type":"patent","ip_type_label_zh":"专利","published_at":"2026-04-10 00:00:00","scraped_at":"2026-04-10 16:32:35","title_zh":"UPC 上诉法院：未全覆盖成员国将拒授统一专利效力","title":"JUB - Effet unitaire refusé sans couverture complète des États membres","summary_zh":"UPC 上诉法院确认，欧洲专利仅在覆盖所有参与国且权利要求一致时方可获统一效力。本案因申请日早于马耳他加入 EPO 时间，导致领土覆盖不全，法院驳回灵活适用请求，严格解释欧盟第 1257/2012 号条例，明确此类专利无法享有统一保护。","core_points_zh":["统一专利效力要求覆盖所有参与成员国且权利要求完全一致","因历史原因未指定马耳他的旧案无法通过灵活解释获补救","法院严格适用条例，拒绝因非申请人过错而豁免领土完整性"],"insight_zh":"中国企业在欧布局需核查旧案领土覆盖情况，避免因缺失成员国导致统一效力落空。新申请应确保指定所有参与国，并关注 UPC 对形式要件的严苛审查趋势。","insight_points_zh":["存量专利需排查是否因缺漏成员国而丧失统一保护资格","新申请策略须确保全境覆盖以符合 UPC 严格形式审查"],"primary_scope":"eu","geo_label_zh":"欧洲层面","url":"https://www.mondaq.com/patent/1771264/jub-effet-unitaire-refus%c3%a9-sans-couverture-compl%c3%a8te-des-%c3%89tats-membres","analysis_depth":"full_text","analysis_depth_label_zh":"全文分析","analysis_depth_label_en":"Full-text analysis","analysis_depth_desc_zh":"基于较完整正文生成，结论可直接用于深入研判。","analysis_depth_desc_en":"Generated from a relatively complete article body for deeper reading."},{"id":8859,"source_id":"mondaq","source_name":"Mondaq","category":"media","ip_type":"patent","ip_type_label_zh":"专利","published_at":"2026-04-07 00:00:00","scraped_at":"2026-04-08 16:34:26","title_zh":"UPC 上诉院裁定：登录系统不构成应诉管辖","title":"Court Of Appeal, March 27, 2026, Decision, UPC_CoA_409/2025, UPC_CoA_410/2025, UPC_CoA_420/2025","summary_zh":"统一专利法院（UPC）上诉院作出裁决，明确被告仅登录案件管理系统查看文件，不构成《布鲁塞尔条例 Ia》下的“应诉”行为。法院指出，确立管辖权需被告采取实质性步骤，如提交初步异议或答辩状。该判决厘清了程序性访问与接受管辖的界限，防止因被动查看文件而被视为自愿接受法院管辖。","core_points_zh":["仅登录 UPC 系统查看文件不视为接受法院管辖权","必须提交初步异议或实体答辩状才构成正式应诉","明确了布鲁塞尔条例下确立国际管辖权的具体行为标准"],"insight_zh":"中国企业在应对 UPC 诉讼时，仅登录查看案情不会导致丧失管辖权异议权利。但需警惕后续任何实质性文件提交行为，务必在专业律师指导下制定应诉策略，避免因程序操作失误而被视为默认接受管辖。","insight_points_zh":["被动查看案件文件安全，不会触发管辖权确立后果","提交任何正式文书前须审慎评估，以免被视为接受管辖"],"primary_scope":"eu","geo_label_zh":"欧洲层面","url":"https://www.mondaq.com/patent/1769860/court-of-appeal-march-27-2026-decision-upccoa4092025-upccoa4102025-upccoa4202025","analysis_depth":"full_text","analysis_depth_label_zh":"全文分析","analysis_depth_label_en":"Full-text analysis","analysis_depth_desc_zh":"基于较完整正文生成，结论可直接用于深入研判。","analysis_depth_desc_en":"Generated from a relatively complete article body for deeper reading."}],"report_item_count":2,"report_type":"daily","report_name_zh":"每日欧洲IP战报","report_name_en":"Daily Europe IP Watch","report_role_zh":"值守快报","report_role_en":"Watch Brief","report_focus_zh":"聚焦最近24到48小时的新增变化、机构动作、法院动态与执法信号。","report_focus_en":"Weighted toward same-day changes, institutional moves, court developments, and enforcement signals.","item_count":2,"source_count":1,"source_tier_core":1,"source_tier_stable":0,"source_tier_watch":0,"date_from":"2026-04-04 23:59:59","date_to":"2026-04-11 23:59:59","comparison_label_zh":"较上一窗口","comparison_label_en":"vs previous window","comparison_period_from